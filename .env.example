NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Redis: progreso de scan (Issues 1.1 / 1.2). Sin REDIS_URL el POST /api/scan funciona pero no persiste.
REDIS_URL=redis://localhost:6379
SCAN_SESSION_TTL_SECONDS=1800
PROVIDER_TIMEOUT_MS=15000
# true = POST /api/scan exige Redis (Issue 1.1). En local sin Redis: false
SCAN_REQUIRE_REDIS=true

# Optional Nym routing toggle (adapter scaffold)
NYM_ENABLED=false
NYM_BASE_URL=
NYM_CLIENT_ID=tezcatli-backend
NYM_PREFERRED_GATEWAY=
NYM_FORCE_TLS=true

# Arkham
ARKHAM_API_BASE_URL=https://api.arkm.com
ARKHAM_API_KEY=

# Zerion (proposal to replace DeBank)
ZERION_API_BASE_URL=https://api.zerion.io/v1
ZERION_API_KEY=
ZERION_PORTFOLIO_PATH_TEMPLATE=/wallets/{address}/portfolio

# Neynar
NEYNAR_API_BASE_URL=https://api.neynar.com
NEYNAR_API_KEY=
NEYNAR_LOOKUP_PATH_TEMPLATE=/v2/farcaster/user/bulk-by-address/?addresses={address}
