NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Redis: progreso de scan. Sin REDIS_URL el POST /api/scan funciona pero no persiste.
# Si defines REDIS_URL, el servidor necesita Redis accesible al arrancar. En macOS, si cuelga, prueba redis://127.0.0.1:6379
REDIS_URL=redis://localhost:6379
SCAN_SESSION_TTL_SECONDS=1800
# timeout orquestador; HTTP de conectores ≈ valor − 500 ms
PROVIDER_TIMEOUT_MS=15000
# true = POST /api/scan exige Redis. En local sin Redis: false
SCAN_REQUIRE_REDIS=true

# Nym mix-fetch para salidas HTTP (fallback a fetch si falla)
NYM_ENABLED=false
NYM_BASE_URL=
NYM_CLIENT_ID=tezcatli-backend
NYM_PREFERRED_GATEWAY=
NYM_FORCE_TLS=true
NYM_RETRY_ATTEMPTS=3
NYM_RETRY_BASE_MS=250
NYM_RETRY_JITTER_MS=150
NYM_ALLOW_DIRECT_FALLBACK=true

# Noise queries (Issue 2.2 - k-anonymity)
NOISE_ENABLED=false
NOISE_DECOYS_MIN=2
NOISE_DECOYS_MAX=4
NOISE_MAX_DECOYS_PER_PROVIDER=4

# Arkham (path por defecto multichain /all)
ARKHAM_API_BASE_URL=https://api.arkm.com
ARKHAM_INTELLIGENCE_PATH_TEMPLATE=/intelligence/address/{address}/all
ARKHAM_API_KEY=

# Zerion (proposal to replace DeBank)
ZERION_API_BASE_URL=https://api.zerion.io/v1
ZERION_API_KEY=
ZERION_PORTFOLIO_PATH_TEMPLATE=/wallets/{address}/portfolio

# Neynar
NEYNAR_API_BASE_URL=https://api.neynar.com
NEYNAR_API_KEY=
NEYNAR_LOOKUP_PATH_TEMPLATE=/v2/farcaster/user/bulk-by-address/?addresses={address}
